# RUMPUS ENGINE — creator-uploaded models (build 974). Data only: nothing in this
# folder may ever execute, and nothing but .glb files is ever served from it.
<IfModule mod_php.c>
  php_flag engine off
</IfModule>
RemoveHandler .php .phtml .phar .pl .py .cgi .fcgi
RemoveType .php .phtml .phar
Options -ExecCGI -Indexes

Require all denied
<FilesMatch "\.glb$">
  Require all granted
  ForceType model/gltf-binary
  <IfModule mod_headers.c>
    Header set Cache-Control "public, max-age=604800"
  </IfModule>
</FilesMatch>
