# RUMPUS ENGINE — creator-uploaded sounds (build 975). Data only: nothing here executes,
# and only audio files are ever served.
<IfModule mod_php.c>
  php_flag engine off
</IfModule>
RemoveHandler .php .phtml .phar .pl .py .cgi .fcgi
RemoveType .php .phtml .phar
Options -ExecCGI -Indexes

Require all denied
<FilesMatch "\.(mp3|ogg|wav)$">
  Require all granted
  <IfModule mod_headers.c>
    Header set Cache-Control "public, max-age=604800"
  </IfModule>
</FilesMatch>
